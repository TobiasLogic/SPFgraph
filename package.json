{
  "name": "@tobiascantcode/spfgraph",
  "version": "0.1.3",
  "description": "Run LLMs locally in your terminal. Supports custom .pt GPT-2 decoder checkpoints and GGUF models, with a live dashboard of throughput, VRAM, and chat.",
  "type": "commonjs",
