  },
  "homepage": "https://github.com/TobiasLogic/SPFgraph#readme",
  "dependencies": {
    "blessed": "^0.1.81",
    "blessed-contrib": "^4.11.0",
    "chalk": "^4.1.2",
    "commander": "^11.1.0"
  },
